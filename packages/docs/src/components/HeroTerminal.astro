---
/**
 * HeroTerminal — 52-second auto-playing, looping CSS-keyframe terminal.
 *
 * Every frame from `heroFrames` is rendered as a `<div data-frame>` at
 * build time. A single parent animation clock drives their reveal: each
 * frame's `animation-delay` is set to `t` seconds, referring to the
 * shared `mt-frame-reveal` keyframe defined in `landing.css`. The
 * terminal container loops via `animation-iteration-count: infinite`
 * with a 3-second pause built into the cycle.
 *
 * Reduced motion (`prefers-reduced-motion: reduce`) strips the animation
 * and shows every frame at once — see the media query in `landing.css`.
 * No runtime JS.
 */
import { heroFrames } from '../data/terminal-script';

const TOTAL_DURATION_S = 55; // 52s of content + 3s pause before loop

function kindClass(kind: string): string {
  return `mt-line mt-line--${kind}`;
}
---

<div
  class="mt-terminal mt-terminal--hero"
  data-mt-frames
  role="img"
  aria-label="52-second terminal demo: maina setup, context, verify, commit"
>
  <div class="mt-chrome" aria-hidden="true">
    <span class="mt-chrome__dot mt-chrome__dot--r"></span>
    <span class="mt-chrome__dot mt-chrome__dot--y"></span>
    <span class="mt-chrome__dot mt-chrome__dot--g"></span>
    <span class="mt-chrome__title">~/project · maina</span>
  </div>
  <pre class="mt-body" style={`--mt-duration: ${TOTAL_DURATION_S}s`}>
{heroFrames.map((f, idx) => (
  <div
    data-frame={idx}
    class={kindClass(f.kind)}
    style={`animation-delay: ${f.t}s`}
  >{f.text}</div>
))}<div data-frame={heroFrames.length} class="mt-cursor" aria-hidden="true"></div>
  </pre>
</div>

<style is:global>
  /* ─── HeroTerminal styles ───────────────────────────────────────────
     Scoped via class prefixes (`mt-` = maina terminal) to avoid Starlight
     theme collisions. Tokens come from the Tailwind 4 @theme block in
     landing.css. */

  .mt-terminal {
    background: var(--color-terminal-bg);
    border: 1px solid var(--color-bg-elev);
    border-radius: var(--radius);
    overflow: hidden;
    font-family: var(--font-mono);
    color: var(--color-ink);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.6);
  }

  .mt-terminal--hero {
    width: 100%;
    max-width: 560px;
  }

  .mt-chrome {
    display: flex;
    gap: 6px;
    align-items: center;
    padding: 10px 12px;
    background: var(--color-bg-elev);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 12px;
  }

  .mt-chrome__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .mt-chrome__dot--r { background: oklch(64% 0.18 25); }
  .mt-chrome__dot--y { background: oklch(78% 0.14 85); }
  .mt-chrome__dot--g { background: oklch(70% 0.15 145); }

  .mt-chrome__title {
    margin-left: 8px;
    color: var(--color-ink-muted);
    letter-spacing: 0.02em;
  }

  .mt-body {
    margin: 0;
    padding: 14px 16px 18px;
    font-size: 12.5px;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    min-height: 360px;
  }

  .mt-line {
    opacity: 0;
    animation-name: mt-frame-reveal;
    animation-duration: 0.6s;
    animation-fill-mode: forwards;
    animation-timing-function: ease-out;
    animation-iteration-count: 1;
  }

  .mt-line--input { color: var(--color-ink); }
  .mt-line--output { color: var(--color-ink-muted); }
  .mt-line--ok { color: var(--color-terminal-green); }
  .mt-line--warn { color: oklch(82% 0.14 85); }
  .mt-line--err { color: var(--color-terminal-red); }
  .mt-line--header {
    color: var(--color-ink-muted);
    text-align: center;
    font-style: italic;
    margin-bottom: 6px;
  }

  .mt-cursor {
    display: inline-block;
    width: 8px;
    height: 14px;
    margin-left: 4px;
    background: var(--color-accent);
    vertical-align: text-bottom;
    animation: mt-cursor-blink 1s steps(2, start) infinite;
  }
</style>
