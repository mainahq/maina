---
/**
 * GovernancePainStrip — three org-voice recognition cards for /cloud.
 * Same rhythm as `PainStrip` on /, different copy. Cap line closes.
 */
import { GOVERNANCE_PAIN_STRIP } from '../data/cloud-landing';
---

<section class="gov-pain">
  <ul class="gov-pain__cards">
    {GOVERNANCE_PAIN_STRIP.cards.map((card) => (
      <li class="gov-pain__card">
        <p class="gov-pain__label">{card.label}</p>
        <p class="gov-pain__body">{card.body}</p>
      </li>
    ))}
  </ul>
  <p class="gov-pain__cap">{GOVERNANCE_PAIN_STRIP.cap}</p>
</section>

<style is:global>
  .gov-pain {
    max-width: 1100px;
    margin: 60px auto;
    padding: 0 24px;
  }

  .gov-pain__cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .gov-pain__cards { grid-template-columns: repeat(3, 1fr); }
  }

  .gov-pain__card {
    background: var(--color-bg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 20px 22px;
  }

  .gov-pain__label {
    margin: 0 0 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .gov-pain__body {
    margin: 0;
    color: var(--color-ink);
    font-size: 15px;
    line-height: 1.55;
  }

  .gov-pain__cap {
    text-align: center;
    margin: 32px 0 0;
    color: var(--color-ink-muted);
    font-size: 14px;
  }
</style>
