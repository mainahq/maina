---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<section class="hero">
  <div class="hero-prompt">~/project $</div>
  <h1>AI writes 41% of your code.<br><span class="accent">Who's checking it?</span></h1>
  <p class="hero-subtitle">
    Verification-first developer OS. CLI + MCP server that proves AI-generated code is correct before it merges.
  </p>
  <div class="hero-actions">
    <a href={`${base}/quickstart`} class="btn-primary">Get Started</a>
    <a href="https://github.com/mainahq/maina" class="btn-secondary">GitHub</a>
  </div>
  <div class="install-cmd">
    <code>curl -fsSL https://api.mainahq.com/install | bash</code>
  </div>
</section>
