---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<section class="hero">
  <div class="hero-prompt">~/project $</div>
  <h1>AI writes 41% of your code.<br><span class="accent">Who's checking it?</span></h1>
  <p class="hero-subtitle">
    19+ tools &middot; 7 languages &middot; 12 AI tools &middot; 0 config
  </p>
  <div class="hero-actions">
    <a href={`${base}/getting-started`} class="btn-primary">Get Started</a>
    <a href="https://github.com/mainahq/maina" class="btn-secondary">GitHub</a>
  </div>
  <div class="install-cmd">
    <code>curl -fsSL https://api.mainahq.com/install | bash</code>
  </div>
  <div class="metrics">
    <div class="metric">
      <div class="metric-value">19+</div>
      <div class="metric-label">verify tools</div>
    </div>
    <div class="metric">
      <div class="metric-value">12</div>
      <div class="metric-label">AI tools</div>
    </div>
    <div class="metric">
      <div class="metric-value">38+</div>
      <div class="metric-label">commands</div>
    </div>
    <div class="metric">
      <div class="metric-value">10</div>
      <div class="metric-label">MCP tools</div>
    </div>
  </div>
</section>
