---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<section class="hero">
  <div class="hero-prompt">~/project $</div>
  <h1>AI writes 41% of your code.<br><span class="accent">Who's checking it?</span></h1>
  <p class="hero-subtitle">
    18 tools &middot; 7 languages &middot; 1 command &middot; 0 config
  </p>
  <div class="hero-actions">
    <a href={`${base}/getting-started`} class="btn-primary">Get Started</a>
    <a href="https://github.com/mainahq/maina" class="btn-secondary">GitHub</a>
  </div>
  <div class="install-cmd">
    <code>bun add -g @mainahq/cli && maina init --install</code>
  </div>
  <div class="metrics">
    <div class="metric">
      <div class="metric-value">18+</div>
      <div class="metric-label">tools</div>
    </div>
    <div class="metric">
      <div class="metric-value">7</div>
      <div class="metric-label">languages</div>
    </div>
    <div class="metric">
      <div class="metric-value">1,167+</div>
      <div class="metric-label">tests</div>
    </div>
    <div class="metric">
      <div class="metric-value">0</div>
      <div class="metric-label">config</div>
    </div>
  </div>
</section>
