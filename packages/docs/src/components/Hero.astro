---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<section class="hero">
  <img src={`${base}/favicon.svg`} alt="Maina" width="100" height="125" class="hero-logo" />
  <h1>Stop shipping broken AI code.</h1>
  <p class="hero-subtitle">
    AI writes 41% of code today — with 1.7x more defects. Maina is the verification layer that proves every change is correct before it merges. One CLI. Any language. Any AI tool.
  </p>
  <div class="hero-actions">
    <a href={`${base}/getting-started`} class="btn-primary">Get Started</a>
    <a href="https://www.npmjs.com/package/@mainahq/cli" class="btn-secondary">npm: @mainahq/cli</a>
  </div>
  <div class="install-cmd">
    <code>bun add -g @mainahq/cli && maina init --install</code>
  </div>
  <div class="metrics">
    <div class="metric">
      <div class="metric-value">16</div>
      <div class="metric-label">verification tools</div>
    </div>
    <div class="metric">
      <div class="metric-value">6</div>
      <div class="metric-label">languages</div>
    </div>
    <div class="metric">
      <div class="metric-value">100%</div>
      <div class="metric-label">benchmark score</div>
    </div>
    <div class="metric">
      <div class="metric-value">0</div>
      <div class="metric-label">config needed</div>
    </div>
  </div>
</section>

<style>
  .install-cmd {
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    background: var(--sl-color-gray-6, #f3f4f6);
    border-radius: 0.5rem;
    display: inline-block;
  }
  .install-cmd code {
    font-size: 0.875rem;
    color: var(--sl-color-gray-1, #374151);
  }
  :global([data-theme='dark']) .install-cmd {
    background: var(--sl-color-gray-5, #1f2937);
  }
  :global([data-theme='dark']) .install-cmd code {
    color: var(--sl-color-gray-1, #e5e7eb);
  }
</style>
