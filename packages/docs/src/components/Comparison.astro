---
/**
 * Comparison — "What this replaces." Matrix with the canonical rows
 * plus the new `.cursorrules` row. Cell values come from `landing.ts`.
 *
 * NEEDS CLARIFICATION (plan.md open Q4): sign off on the .cursorrules
 * row cells — currently [✗, ✗, ✗, ✗, Free]. Flagged in the PR body.
 */
import { COMPARISON } from '../data/landing';

// Filter out rows still flagged `draft: true` in landing.ts — these
// are waiting on reviewer sign-off (see plan.md open Q4).
const rows = COMPARISON.rows.filter((r) => !('draft' in r && r.draft));
---

<section class="cmp-v2" id="comparison">
  <h2 class="cmp-v2__title">{COMPARISON.header}</h2>
  <div class="cmp-v2__scroll">
    <table class="cmp-v2__table">
      <thead>
        <tr>
          <th scope="col" class="cmp-v2__col-head cmp-v2__col-head--name"></th>
          {COMPARISON.columns.map((c) => (
            <th scope="col" class="cmp-v2__col-head">{c.label}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class={'highlighted' in row && row.highlighted ? 'cmp-v2__row cmp-v2__row--us' : 'cmp-v2__row'}>
            <th scope="row" class="cmp-v2__row-head">{row.name}</th>
            {row.cells.map((cell) => (
              <td class="cmp-v2__cell">{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style is:global>
  .cmp-v2 {
    max-width: 1100px;
    margin: 80px auto;
    padding: 0 24px;
  }

  .cmp-v2__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    text-align: center;
    margin: 0 0 28px;
    color: var(--color-ink);
  }

  .cmp-v2__scroll {
    overflow-x: auto;
  }

  .cmp-v2__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .cmp-v2__col-head,
  .cmp-v2__row-head,
  .cmp-v2__cell {
    padding: 12px 14px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-ink);
  }

  .cmp-v2__col-head {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .cmp-v2__row-head {
    font-weight: 600;
  }

  .cmp-v2__row--us .cmp-v2__row-head {
    color: var(--color-accent);
  }

  .cmp-v2__row--us .cmp-v2__cell {
    color: var(--color-ink);
  }

  .cmp-v2__cell {
    color: var(--color-ink-muted);
  }
</style>
