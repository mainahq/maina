---
/**
 * CloudFeatureGrid — six cloud-capability cards. Titles + body copy
 * from `cloud-landing.ts`; body may contain backticked phrases that
 * render as inline <code>.
 */
import { CLOUD_FEATURE_GRID } from '../data/cloud-landing';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
const resolveHref = (href: string): string =>
  href.startsWith('/') ? `${base}${href}` : href;

const labelPattern = /(`[^`]+`)/g;
const cards = CLOUD_FEATURE_GRID.cards.map((c) => ({
  ...c,
  bodyParts: c.body.split(labelPattern),
}));
---

<section class="cloud-grid" id="cloud-features">
  <div class="cloud-grid__head">
    <span class="section-eyebrow">// cloud</span>
    <h2 class="cloud-grid__title">{CLOUD_FEATURE_GRID.header}</h2>
  </div>

  <ul class="cloud-grid__list">
    {cards.map((c) => (
      <li class="cloud-grid__card" id={`cloud-${c.id}`}>
        <h3 class="cloud-grid__name">{c.title}</h3>
        <p class="cloud-grid__body">
          {c.bodyParts.map((p) => (
            p.startsWith('`') && p.endsWith('`')
              ? <code>{p.slice(1, -1)}</code>
              : <>{p}</>
          ))}
        </p>
        <p class="cloud-grid__proof">
          <span>Proof: </span>
          {c.proofLinks.map((l, idx) => (
            <span>
              <a href={resolveHref(l.href)}>{l.label}</a>
              <span>{idx < c.proofLinks.length - 1 ? ", " : "."}</span>
            </span>
          ))}
        </p>
      </li>
    ))}
  </ul>
</section>

<style is:global>
  .cloud-grid {
    max-width: 1100px;
    margin: 80px auto;
    padding: 0 24px;
  }

  .cloud-grid__head {
    text-align: center;
    margin-bottom: 36px;
  }

  .cloud-grid__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    margin: 0;
    color: var(--color-ink);
  }

  .cloud-grid__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .cloud-grid__list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .cloud-grid__list { grid-template-columns: repeat(3, 1fr); }
  }

  .cloud-grid__card {
    background: var(--color-bg-elev);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cloud-grid__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .cloud-grid__body {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .cloud-grid__body code {
    background: rgba(255, 255, 255, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-ink);
  }

  .cloud-grid__proof {
    margin: auto 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-muted);
  }

  .cloud-grid__proof a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .cloud-grid__proof a:hover { text-decoration: underline; }
</style>
