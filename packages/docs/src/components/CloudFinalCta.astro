---
/**
 * CloudFinalCta — two side-by-side cards closing the cloud page.
 * Card A: join the private beta (anchors to the waitlist form).
 * Card B: try the OSS tonight (shows INSTALL_COMMAND, links to /).
 *
 * INSTALL_COMMAND is re-exported from cloud-landing.ts so both pages
 * share the same constant.
 */
import { CLOUD_FINAL_CTA } from '../data/cloud-landing';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
const resolveHref = (href: string): string =>
  href.startsWith('/') ? `${base}${href}` : href;

const ossDocsHref = resolveHref(CLOUD_FINAL_CTA.ossCard.docsTarget);
---

<section class="cloud-final" id="cloud-final">
  <h2 class="cloud-final__title">{CLOUD_FINAL_CTA.header}</h2>
  <div class="cloud-final__grid">
    <div class="cloud-final__card cloud-final__card--beta">
      <h3 class="cloud-final__card-title">{CLOUD_FINAL_CTA.waitlistCard.title}</h3>
      <p class="cloud-final__card-body">{CLOUD_FINAL_CTA.waitlistCard.body}</p>
      <a class="cloud-final__btn" href={CLOUD_FINAL_CTA.waitlistCard.target}>
        {CLOUD_FINAL_CTA.waitlistCard.ctaLabel}
      </a>
    </div>
    <div class="cloud-final__card cloud-final__card--oss">
      <h3 class="cloud-final__card-title">{CLOUD_FINAL_CTA.ossCard.title}</h3>
      <p class="cloud-final__card-body">{CLOUD_FINAL_CTA.ossCard.body}</p>
      <div class="cloud-final__install">
        <input
          id="cloud-final-install"
          class="cloud-final__install-input"
          type="text"
          readonly
          value={CLOUD_FINAL_CTA.ossCard.install}
          aria-label="Install command — read-only, select to copy"
        />
        <button
          type="button"
          class="cloud-final__install-copy"
          data-copy-target="#cloud-final-install"
          aria-label="Copy install command"
        >Copy</button>
      </div>
      <a class="cloud-final__link" href={ossDocsHref}>{CLOUD_FINAL_CTA.ossCard.docsLabel}</a>
    </div>
  </div>
</section>

<style is:global>
  .cloud-final {
    max-width: 1000px;
    margin: 80px auto;
    padding: 0 24px;
  }

  .cloud-final__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    text-align: center;
    margin: 0 0 28px;
    color: var(--color-ink);
  }

  .cloud-final__grid {
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .cloud-final__grid { grid-template-columns: 1fr 1fr; }
  }

  .cloud-final__card {
    background: var(--color-bg-elev);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .cloud-final__card--beta { border-color: var(--color-accent); }

  .cloud-final__card-title {
    font-family: var(--font-display);
    font-size: 20px;
    margin: 0;
    color: var(--color-ink);
  }

  .cloud-final__card-body {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .cloud-final__btn {
    align-self: flex-start;
    margin-top: auto;
    padding: 10px 16px;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
  }

  .cloud-final__install {
    display: flex;
    background: var(--color-terminal-bg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    overflow: hidden;
  }

  .cloud-final__install-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    color: #fafaf9;
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 10px 12px;
    outline: none;
  }

  .cloud-final__install-copy {
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border: 0;
    padding: 0 14px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 600;
    cursor: pointer;
  }

  .cloud-final__link {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .cloud-final__link:hover { color: var(--color-accent); }
</style>
