---
import { FOOTER } from '../data/landing';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
const resolveHref = (href: string): string =>
  href.startsWith('/') ? `${base}${href}` : href;

// Hardcoding the copyright year goes stale next January. Derive it
// at build time.
const year = new Date().getFullYear();
---

<footer class="footer-v2">
  <p class="footer-v2__tagline">{FOOTER.tagline}</p>
  <div class="footer-v2__links">
    {FOOTER.links.map((l) => (
      <a href={resolveHref(l.href)} rel="noopener">{l.label}</a>
    ))}
  </div>
  <p class="footer-v2__copy">&copy; {year} Maina contributors</p>
</footer>

<style is:global>
  .footer-v2 {
    max-width: 1100px;
    margin: 60px auto 40px;
    padding: 40px 24px 20px;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-ink-muted);
    font-size: 13px;
  }

  .footer-v2__tagline {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    color: var(--color-ink);
  }

  .footer-v2__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
    margin-bottom: 18px;
    font-family: var(--font-mono);
  }

  .footer-v2__links a {
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .footer-v2__links a:hover {
    color: var(--color-accent);
  }

  .footer-v2__copy {
    margin: 0;
    font-size: 12px;
  }
</style>
