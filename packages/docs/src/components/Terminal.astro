---
---

<section class="terminal-section">
  <div class="terminal">
    <div class="terminal-dots">
      <span class="dot-red"></span>
      <span class="dot-yellow"></span>
      <span class="dot-green"></span>
    </div>
    <div class="terminal-body">
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">bunx maina init</span>
      </div>
      <div class="line">
        <span class="dim">  Detecting project...</span>
      </div>
      <div class="line">
        <span class="pass">  Found:</span> <span class="accent">TypeScript + Bun monorepo</span>
      </div>
      <div class="line">
        <span class="dim">  Writing .maina/constitution.md</span>
      </div>
      <div class="line">
        <span class="pass">  Ready.</span> <span class="dim">Run</span> <span class="cmd">maina verify</span> <span class="dim">to check your code.</span>
      </div>
      <div class="line">&nbsp;</div>
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">maina commit</span>
      </div>
      <div class="line">
        <span class="dim">  Staging changes...</span>
      </div>
      <div class="line">
        <span class="accent">  Syntax guard</span> <span class="pass">passed</span> <span class="dim">(0.3s)</span>
      </div>
      <div class="line">
        <span class="accent">  Semgrep</span> <span class="pass">passed</span> <span class="dim">(1.2s)</span>
      </div>
      <div class="line">
        <span class="accent">  Slop detector</span> <span class="pass">passed</span> <span class="dim">(0.8s)</span>
      </div>
      <div class="line">
        <span class="accent">  AI review</span> <span class="pass">approved</span> <span class="dim">(4.1s)</span>
      </div>
      <div class="line">
        <span class="pass">  Committed:</span> <span class="cmd">feat(core): add context engine caching</span>
      </div>
    </div>
  </div>
</section>
