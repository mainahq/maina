      <span class="dot-red"></span>
      <span class="dot-yellow"></span>
      <span class="dot-green"></span>
    </div>
    <div class="terminal-body">
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">curl -fsSL https://api.mainahq.com/install | bash</span>
      </div>
      <div class="line">&nbsp;</div>
      <div class="line">
        <span class="pass">  ✓</span> <span class="dim">OS: macOS (arm64)</span>
      </div>
      <div class="line">
        <span class="pass">  ✓</span> <span class="dim">Package manager: bun</span>
      </div>
      <div class="line">
        <span class="pass">  ✓</span> <span class="accent">Claude Code</span> <span class="dim">· </span><span class="accent">Cursor</span> <span class="dim">· </span><span class="accent">VS Code</span>
      </div>
      <div class="line">
        <span class="pass">  ✓</span> <span class="dim">MCP configured for 3 tools</span>
      </div>
      <div class="line">&nbsp;</div>
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">maina wiki init</span>
      </div>
