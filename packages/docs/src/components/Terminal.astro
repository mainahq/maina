        <span class="accent">  Syntax guard</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">Semgrep</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">Trivy</span> <span class="pass">passed</span>
      </div>
      <div class="line">
        <span class="accent">  Wiki lint</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">AI review</span> <span class="pass">passed</span>
      </div>
      <div class="line">
        <span class="pass">  Verification passed</span> <span class="dim">(11.2s, 12 tools)</span>
      </div>
      <div class="line">
        <span class="pass">  Committed:</span> <span class="cmd">feat(core): add user authentication</span>
      </div>
    </div>
  </div>
</section>
