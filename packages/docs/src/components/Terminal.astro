---
---

<section class="terminal-section">
  <div class="terminal">
    <div class="terminal-dots">
      <span class="dot-red"></span>
      <span class="dot-yellow"></span>
      <span class="dot-green"></span>
    </div>
    <div class="terminal-body">
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">bun add -g @mainahq/cli</span>
      </div>
      <div class="line">
        <span class="pass">  installed</span> <span class="dim">@mainahq/cli@0.3.0</span>
      </div>
      <div class="line">&nbsp;</div>
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">maina init --install</span>
      </div>
      <div class="line">
        <span class="dim">  Detecting project...</span>
      </div>
      <div class="line">
        <span class="pass">  Stack:</span> <span class="accent">TypeScript + Bun</span>
      </div>
      <div class="line">
        <span class="pass">  Tools:</span> <span class="accent">biome, semgrep, trivy, secretlint</span> <span class="dim">(4 installed)</span>
      </div>
      <div class="line">
        <span class="pass">  Ready.</span>
      </div>
      <div class="line">&nbsp;</div>
      <div class="line">
        <span class="prompt">$ </span><span class="cmd">maina commit</span>
      </div>
      <div class="line">
        <span class="accent">  Syntax guard</span> <span class="pass">passed</span> <span class="dim">(0.3s)</span>
      </div>
      <div class="line">
        <span class="accent">  Semgrep</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">Trivy</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">Secretlint</span> <span class="pass">passed</span>
      </div>
      <div class="line">
        <span class="accent">  Slop detector</span> <span class="pass">passed</span> <span class="dim">· </span><span class="accent">AI review</span> <span class="pass">passed</span>
      </div>
      <div class="line">
        <span class="pass">  Verification passed</span> <span class="dim">(8.9s, 8 tools)</span>
      </div>
      <div class="line">
        <span class="pass">  Committed:</span> <span class="cmd">feat(core): add user authentication</span>
      </div>
    </div>
  </div>
</section>
