---
// A/B scaffold. `HERO_VARIANT=v2` at build time swaps the hero for the
// v2 stub which errors loudly — implement Hero.v2.astro before enabling.
import HeroV1 from '../components/Hero.astro';
import HeroV2 from '../components/Hero.v2.astro';
import PainStrip from '../components/PainStrip.astro';
import Terminal from '../components/Terminal.astro';
import Engines from '../components/Engines.astro';
import ReceiptGallery from '../components/ReceiptGallery.astro';
import ProofStrip from '../components/ProofStrip.astro';
import StackFit from '../components/StackFit.astro';
import Comparison from '../components/Comparison.astro';
import FinalCta from '../components/FinalCta.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import { META, NAV } from '../data/landing';
import cliPackage from '../../../cli/package.json';
import '../styles/landing.css';

// Fail the build if the CLI version isn't readable — shipping JSON-LD with
// `softwareVersion: "0.0.0"` is worse than no version at all because it
// poisons downstream search indexes. The previous `?? '0.0.0'` fallback
// masked a real config error.
const cliVersion = (cliPackage as { version?: unknown }).version;
if (typeof cliVersion !== 'string' || cliVersion.trim() === '') {
  throw new Error('packages/cli/package.json must declare a non-empty version');
}

const HERO_VARIANT = import.meta.env.HERO_VARIANT ?? 'v1';
const Hero = HERO_VARIANT === 'v2' ? HeroV2 : HeroV1;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

// JSON-LD softwareVersion is locked to the CLI's package.json at build
// time so it can never drift behind a release (see docs-manifest SSOT
// rule). featureList enumerates engines + surfaces, not tool counts —
// counts live in the commands/mcp docs where they are also regenerated.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Maina',
  description: META.description,
  url: META.url,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows (WSL)',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  softwareVersion: cliVersion,
  programmingLanguage: ['TypeScript', 'Python', 'Go', 'Rust', 'C#', 'Java', 'PHP'],
  featureList: [
    'Context Engine (4-layer retrieval, AST + PageRank)',
    'Verify Engine (diff-only verification pipeline)',
    'Progressive MCP server',
    'Constitution derivation + versioned prompts',
  ],
  codeRepository: 'https://github.com/mainahq/maina',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Prevent FOUC: apply theme before paint
      (function () {
        var stored = localStorage.getItem('starlight-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <title>{META.title}</title>
    <meta name="description" content={META.description} />
    <meta property="og:title" content={META.title} />
    <meta property="og:description" content={META.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={META.url} />
    {META.ogImage && (
      <meta property="og:image" content={META.ogImage} />
    )}
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <nav class="nav">
      <a href={base} class="nav-brand">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="15 10 105 100" width="30" height="28" style="margin-top:-1px">
          <path d="M60,18 C85,12 100,30 98,55 C96,78 82,98 58,102 C34,106 20,90 20,68 C20,50 32,30 60,18Z" fill="#d6d3d1" />
          <path d="M58,30 C75,26 88,38 86,55 C84,70 74,82 58,85 C42,88 32,78 32,62 C32,48 42,34 58,30Z" fill="#78716c" />
          <path d="M58,45 C68,42 76,50 74,58 C72,66 65,72 58,72 C50,72 44,66 44,58 C44,50 50,44 58,45Z" fill="#f97316" />
          <polygon points="98,42 115,35 108,46" fill="#f97316" />
          <circle cx="86" cy="38" r="3" fill="#fafaf9" />
          <path d="M20,78 C14,92 8,108 12,118 L22,112 C20,100 22,88 24,80Z" fill="#d6d3d1" />
        </svg>
        {NAV.brand}
      </a>
      <div class="nav-right">
        <div class="nav-links">
          {NAV.links.map((l) => (
            <a href={l.href.startsWith('/') ? `${base}${l.href}` : l.href}>{l.label}</a>
          ))}
        </div>
        <button class="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" /></svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
        </button>
      </div>
    </nav>
    <Hero />
    <div class="band-bleed"><PainStrip /></div>
    <Terminal />
    <div class="band-bleed band-hairline"><Engines /></div>
    <ReceiptGallery />
    <ProofStrip />
    <div class="band-bleed"><StackFit /></div>
    <Comparison />
    <div class="band-bleed band-hairline"><FinalCta /></div>
    <Faq />
    <Footer />
    <script is:inline>
      // Copy-to-clipboard — one delegated listener for every button
      // with `data-copy-target`. Guarded by feature detection so the
      // readonly <input> still works for no-clipboard browsers.
      document.addEventListener('click', function (ev) {
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const btn = target.closest('[data-copy-target]');
        if (!btn) return;
        const sel = btn.getAttribute('data-copy-target');
        if (!sel) return;
        const input = document.querySelector(sel);
        if (!input) return;
        const value = input.value;
        const flash = function () {
          const original = btn.textContent;
          btn.textContent = 'Copied';
          setTimeout(function () { btn.textContent = original; }, 1600);
        };
        const fallback = function () {
          input.select();
          document.execCommand('copy');
          flash();
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(value).then(flash, fallback);
        } else {
          fallback();
        }
      });

      // Scroll reveal
      const obs = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        }
      }, { threshold: 0.15 });
      for (const el of document.querySelectorAll('.reveal, .reveal-stagger')) {
        obs.observe(el);
      }

      // Theme toggle
      (function () {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('starlight-theme', next);
        });

        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function (e) {
          if (!localStorage.getItem('starlight-theme')) {
            document.documentElement.setAttribute('data-theme', e.matches ? 'light' : 'dark');
          }
        });
      })();
    </script>
  </body>
</html>
