---
import Hero from '../components/Hero.astro';
import Engines from '../components/Engines.astro';
import Terminal from '../components/Terminal.astro';
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';
import '../styles/landing.css';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Maina — Stop shipping broken AI code</title>
    <meta name="description" content="16-tool verification pipeline that proves AI-generated code is correct before it merges. TypeScript, Python, Go, Rust, C#, Java. Works inside Claude Code, Cursor, Codex." />
    <meta name="keywords" content="code verification, AI code review, code quality, static analysis, mcp server, claude code, cursor, codex, semgrep, trivy, biome, slop detection, visual regression, playwright" />
    <meta property="og:title" content="Maina — Stop shipping broken AI code" />
    <meta property="og:description" content="16-tool verification pipeline for AI-generated code. 6 languages. Works inside your AI tool." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mainahq.com/" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Maina",
      "description": "Verification-first developer OS. 16-tool pipeline that proves AI-generated code is correct before it merges.",
      "url": "https://mainahq.com/",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux, Windows",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "softwareVersion": "0.3.0",
      "programmingLanguage": ["TypeScript", "Python", "Go", "Rust", "C#", "Java"],
      "codeRepository": "https://github.com/beeeku/maina"
    })} />
  </head>
  <body>
    <nav class="nav">
      <a href={base} class="nav-brand">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="15 10 105 100" width="30" height="28" style="margin-top:-1px">
          <path d="M60,18 C85,12 100,30 98,55 C96,78 82,98 58,102 C34,106 20,90 20,68 C20,50 32,30 60,18Z" fill="#1a1a1a"/><path d="M58,30 C75,26 88,38 86,55 C84,70 74,82 58,85 C42,88 32,78 32,62 C32,48 42,34 58,30Z" fill="#333"/><path d="M58,45 C68,42 76,50 74,58 C72,66 65,72 58,72 C50,72 44,66 44,58 C44,50 50,44 58,45Z" fill="#f97316"/><polygon points="98,42 115,35 108,46" fill="#f97316"/><circle cx="86" cy="38" r="3" fill="#fafaf9"/><path d="M20,78 C14,92 8,108 12,118 L22,112 C20,100 22,88 24,80Z" fill="#1a1a1a"/>
        </svg>
        Maina<span class="dot">.</span>
      </a>
      <div class="nav-links">
        <a href={`${base}/getting-started`}>Docs</a>
        <a href={`${base}/commands`}>Commands</a>
        <a href={`${base}/mcp`}>MCP</a>
        <a href="https://github.com/beeeku/maina">GitHub</a>
        <a href={`${base}/getting-started`} class="nav-cta">Get Started</a>
      </div>
    </nav>
    <Hero />
    <Engines />
    <Terminal />
    <Features />
    <Footer />
  </body>
</html>
